---
import { Image } from "astro:assets";
import BackToTopButton from "./BackToTopButton.astro";
import HeaderControls from "./HeaderControls.astro";
import HeadSeo from "./HeadSeo.astro";
import HighlightCard from "./HighlightCard.astro";
import PageFooter from "./PageFooter.astro";
import PageNav from "./PageNav.astro";
import { buildMainNav } from "../../lib/main-nav";
import heroLogo from "../../assets/images/logo.svg";
import profileQr from "../../assets/images/profile-qr.svg";
import goodreadsSnapshot from "../../data/site-content/goodreads-snapshot.json";
import { computeLegacyBuildTimestamp } from "../../lib/build-timestamp";
import {
  loadIndexPageContent,
  type IndexAction,
  type Lang,
  type PageId,
} from "../../lib/index-content";
import { LANGS } from "../../lib/locale-config";
import {
  buildOgImageUrl,
  buildPageAssetHrefs,
  PAGE_LAYOUT,
  UMAMI_WEBSITE_ID,
} from "../../lib/page-shared";
import {
  SOCIAL_CHIP_ICON_CLASS_BY_NAME,
  type SocialChipIconName,
  resolveSocialPlatformFromHref,
} from "../../lib/social-chip-icons";
import { buildSchemaGraphJson } from "../../lib/seo";
import {
  assetHref,
  buildOgLocaleAlternates,
  OG_LOCALE_BY_LANG,
  routeHref,
} from "../../lib/work-project-content";

interface Props {
  readonly lang: Lang;
}

const { lang } = Astro.props as Props;
const content = loadIndexPageContent(lang);
const buildTimestamp = computeLegacyBuildTimestamp(lang);
const currentRoute = content.route;

const canonicalUrl =
  lang === "en"
    ? `${content.site.baseUrl}/`
    : `${content.site.baseUrl}/${content.route}`;
const ogImageUrl = buildOgImageUrl(content.site.baseUrl);
const schemaGraphJson = buildSchemaGraphJson({
  baseUrl: content.site.baseUrl,
  websiteName: content.site.websiteName,
  personName: content.site.personName,
  canonicalUrl,
  ogImageUrl,
  socialProfiles: content.site.socialProfiles,
  lang,
  pageTitle: content.meta.title,
  pageDescription: content.meta.description,
});

const alternateLinks = [
  ...LANGS.map((localeCode) => ({
    hrefLang: localeCode,
    href:
      localeCode === "en"
        ? `${content.site.baseUrl}/`
        : `${content.site.baseUrl}/${content.routes.index[localeCode]}`,
  })),
  { hrefLang: "x-default", href: `${content.site.baseUrl}/` },
] as const;

const ogLocaleAlternates = buildOgLocaleAlternates(lang);
const menuId = `language-menu-index-${lang}`;
const uiLabels = content.site.locale.labels;

const pageAssets = buildPageAssetHrefs(currentRoute);
const darkModeIconHref = assetHref(currentRoute, "icons/theme-dark.svg");
const lightModeIconHref = assetHref(currentRoute, "icons/theme-light.svg");
const goodreadsScriptSource = (() => {
  try {
    const parsed = new URL(content.statsCompact.goodreads.scriptSrc);
    parsed.searchParams.set("num_books", "11");
    return parsed.toString();
  } catch {
    return content.statsCompact.goodreads.scriptSrc;
  }
})();

function routeForAction(pageId: PageId): string {
  return content.routes[pageId][lang];
}

interface ResolvedAction {
  readonly href: string;
  readonly navPageId?: PageId;
  readonly isExternal: boolean;
  readonly isMailto: boolean;
  readonly variantClass: string;
  readonly labelText: string;
  readonly showTrailingArrow: boolean;
}

function stripMailPrefix(label: string): string {
  return label.replace(/^✉\s*/, "");
}

function resolveAction(action: IndexAction): ResolvedAction {
  let href = action.href;
  let navPageId: PageId | undefined;
  if (action.pageId !== undefined) {
    href = routeHref(currentRoute, routeForAction(action.pageId));
    navPageId = action.pageId;
  }
  if (href === undefined) {
    throw new Error("Index action missing href and pageId");
  }

  const isExternal = href.startsWith("http://") || href.startsWith("https://");
  const isMailto = href.startsWith("mailto:");
  const isPageLink = navPageId !== undefined;

  let variantClass =
    action.variant === "primary"
      ? "action-chip action-chip--primary"
      : "action-chip action-chip--secondary";
  if (isPageLink && action.variant === "secondary") {
    variantClass = `${variantClass} action-chip--compact-nav`;
  }

  const resolved: {
    href: string;
    isExternal: boolean;
    isMailto: boolean;
    variantClass: string;
    labelText: string;
    showTrailingArrow: boolean;
    navPageId?: PageId;
  } = {
    href,
    isExternal,
    isMailto,
    variantClass,
    labelText: isMailto ? stripMailPrefix(action.label) : action.label,
    showTrailingArrow: isPageLink && action.variant === "secondary",
  };
  if (navPageId !== undefined) {
    resolved.navPageId = navPageId;
  }
  return resolved;
}

interface SocialChip {
  readonly href: string;
  readonly ariaLabel: string;
  readonly text: string;
  readonly iconName: SocialChipIconName;
  readonly isExternal: boolean;
}

function toSocialChip(action: IndexAction): SocialChip {
  const resolved = resolveAction(action);
  if (resolved.navPageId !== undefined) {
    throw new Error("Top social actions cannot be page links");
  }
  if (!resolved.isMailto) {
    throw new Error("Top social actions must use a mailto href");
  }

  return {
    href: resolved.href,
    ariaLabel: resolved.labelText,
    text: resolved.labelText,
    iconName: "email",
    isExternal: false,
  };
}

const topSocialChips = content.topActions.map((action) => toSocialChip(action));
const profileSocialChips = content.site.socialProfiles.map((href) => {
  const platform = resolveSocialPlatformFromHref(href);
  const label = content.site.locale.socialPlatformLabels[platform];
  return {
    href,
    ariaLabel: label,
    text: label,
    iconName: platform,
    isExternal: true,
  } as const;
});
const socialChips: readonly SocialChip[] = [
  ...topSocialChips,
  ...profileSocialChips,
];
const goodreadsBooks = goodreadsSnapshot.books.slice(0, 11);
const statsBooksHref = `${routeHref(currentRoute, routeForAction("stats"))}#gr_grid_widget_${content.statsCompact.goodreads.widgetId}`;

const viewAllStatsAction: IndexAction = {
  label: content.viewAllStatsLabel,
  pageId: "stats",
  variant: "secondary",
};

const skillChips = [
  "Kotlin", "Swift", "Dart", "Python", "PHP", "Go", "TypeScript", "SQL",
  "Android", "iOS", "Flutter", "Kotlin Multiplatform", "macOS",
  "Laravel", "Computer Vision", "Linux CLI",
  "Agile", "Scrum", "Kanban",
  "Bangla", "Urdu", "English",
] as const;
---

<!doctype html>
<html lang={lang} dir={content.site.locale.dir}>
  <HeadSeo
    title={content.meta.title}
    description={content.meta.description}
    keywords={content.meta.keywords}
    author={content.site.locale.author}
    canonicalUrl={canonicalUrl}
    alternateLinks={alternateLinks}
    ogType="website"
    ogLocale={OG_LOCALE_BY_LANG[lang]}
    ogLocaleAlternates={ogLocaleAlternates}
    ogImageUrl={ogImageUrl}
    ogImageAlt={content.site.locale.ogImageAlt}
    twitterSite={content.site.twitterSite}
    schemaGraphJson={schemaGraphJson}
    googleSiteVerification={content.site.googleSiteVerification}
    umamiWebsiteId={UMAMI_WEBSITE_ID}
    stylesheetHref={pageAssets.stylesheetHref}
    faviconSvgHref={pageAssets.faviconSvgHref}
    favicon32Href={pageAssets.favicon32Href}
    favicon16Href={pageAssets.favicon16Href}
    faviconIcoHref={pageAssets.faviconIcoHref}
    appleTouchIconHref={pageAssets.appleTouchIconHref}
    manifestHref={pageAssets.manifestHref}
  />
  <body
    data-page-id="index"
    data-sw-path={pageAssets.swPath}
    data-goodreads-script-src={goodreadsScriptSource}
  >
    <a class={PAGE_LAYOUT.skipLinkClass} href={`#${PAGE_LAYOUT.mainContentId}`}>
      {uiLabels.skipToMain}
    </a>
    <div class={PAGE_LAYOUT.siteClass}>
      <header id="top">
        <HeaderControls
          currentRoute={currentRoute}
          darkModeIconHref={darkModeIconHref}
          lang={lang}
          languageLinks={content.routes.index}
          languageMenuId={menuId}
          languageMenuLabels={content.site.languageMenuLabels}
          languageSwitcherLabel={content.site.locale.languageSwitcherLabel}
          lightModeIconHref={lightModeIconHref}
          themeDarkLabel={uiLabels.themeDark}
          themeLightLabel={uiLabels.themeLight}
        />

        <div class="header-identity">
          <div class="hero-avatar-card">
            <div class="hero-avatar-flip">
              <div class="hero-avatar-face hero-avatar-face--front">
                <Image
                  class="hero-illustration"
                  alt={content.site.locale.ogImageAlt}
                  src={heroLogo}
                  width={1024}
                  height={1024}
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </div>
              <div
                class="hero-avatar-face hero-avatar-face--back"
                aria-hidden="true"
              >
                <Image
                  class="hero-qr-code"
                  alt=""
                  src={profileQr}
                  width={512}
                  height={512}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </div>
          <div class="header-identity-copy">
            <h1 class="site-title">{content.header.siteTitle}</h1>
            <p class="tagline">{content.header.tagline}</p>
          </div>
        </div>

        <div class="social-chip-row" aria-label={content.socialRowLabel}>
          {
            socialChips.map((chip) => (
              <a
                class="social-chip"
                href={chip.href}
                target={chip.isExternal ? "_blank" : undefined}
                rel={chip.isExternal ? "noreferrer" : undefined}
                aria-label={chip.ariaLabel}
              >
                <span
                  class={`social-chip-icon ${SOCIAL_CHIP_ICON_CLASS_BY_NAME[chip.iconName]}`}
                  aria-hidden="true"
                />
                <span>{chip.text}</span>
              </a>
            ))
          }
        </div>

        <PageNav items={buildMainNav(currentRoute)} />
      </header>

      <main id={PAGE_LAYOUT.mainContentId}>
        <section class="about-section">
          <div class="summary-card summary-card--about">
            {content.summaryCard.map((paragraph) => <p set:html={paragraph} />)}
          </div>
        </section>

        {
          content.sections.map((section, sectionIndex) =>
            section.tags.length > 0 ? null : (
              <section>
                <div class="section-head">
                  <h2
                    class={
                      sectionIndex === 0
                        ? "section-title section-title--minor"
                        : "section-title"
                    }
                  >
                    {section.title}
                  </h2>
                  {section.actions.length > 0 ? (
                    <div class="section-actions">
                      {section.actions.map((action) => {
                        const resolved = resolveAction(action);
                        return (
                          <a
                            class={resolved.variantClass}
                            href={resolved.href}
                            target={resolved.isExternal ? "_blank" : undefined}
                            rel={resolved.isExternal ? "noreferrer" : undefined}
                            data-nav-page-id={resolved.navPageId}
                          >
                            {resolved.isMailto ? (
                              <span
                                class="action-chip-icon action-chip-icon--mail"
                                aria-hidden="true"
                              />
                            ) : null}
                            <span>{resolved.labelText}</span>
                            {resolved.showTrailingArrow ? (
                              <span
                                class="action-chip-arrow"
                                aria-hidden="true"
                              />
                            ) : null}
                          </a>
                        );
                      })}
                    </div>
                  ) : null}
                </div>
                {section.paragraphs.map((paragraph) => (
                  <p set:html={paragraph} />
                ))}
                {section.highlights.length > 0 ? (
                  <div class="highlight-list">
                    {section.highlights.map((highlight) => (
                      <HighlightCard card={highlight} />
                    ))}
                  </div>
                ) : null}
                {section.articles.length > 0 ? (
                  <ul class="article-list">
                    {section.articles.map((article) => (
                      <li class="article-item">
                        <a
                          href={article.href}
                          target="_blank"
                          rel="noreferrer"
                          data-umami-track-article="true"
                        >
                          <h3>{article.title}</h3>
                          <p>{article.summary}</p>
                        </a>
                      </li>
                    ))}
                  </ul>
                ) : null}
                {section.contacts.map((contact) => (
                  <p>{contact}</p>
                ))}
              </section>
            ),
          )
        }

        <section>
          <div class="summary-card stats-card skills-card">
            <div class="section-head">
              <h2 class="section-title">
                {content.statsCompact.wakatime.title}
              </h2>
              <div class="section-actions">
                {
                  (() => {
                    const resolved = resolveAction(viewAllStatsAction);
                    return (
                      <a
                        class={resolved.variantClass}
                        href={resolved.href}
                        data-nav-page-id={resolved.navPageId}
                      >
                        <span>{resolved.labelText}</span>
                        <span class="action-chip-arrow" aria-hidden="true" />
                      </a>
                    );
                  })()
                }
              </div>
            </div>
            <div class="skill-tag-cloud">
              {skillChips.map((skill) => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
          </div>
        </section>

        <section>
          <div class="summary-card stats-card">
            <div class="section-head">
              <h2 class="section-title">
                {content.statsCompact.goodreads.title}
              </h2>
              <div class="section-actions">
                {
                  (() => {
                    const resolved = resolveAction(viewAllStatsAction);
                    return (
                      <a
                        class={resolved.variantClass}
                        href={resolved.href}
                        data-nav-page-id={resolved.navPageId}
                      >
                        <span>{resolved.labelText}</span>
                        <span class="action-chip-arrow" aria-hidden="true" />
                      </a>
                    );
                  })()
                }
              </div>
            </div>
            <p>{content.statsCompact.goodreads.copy}</p>
            <div
              class="goodreads-widget"
              id={`gr_grid_widget_${content.statsCompact.goodreads.widgetId}`}
              data-stats-books-href={statsBooksHref}
            >
              <div class="gr_grid_container">
                {
                  goodreadsBooks.map((book) => (
                    <div class="gr_grid_book_container">
                      <a
                        title={book.title}
                        rel="nofollow noreferrer"
                        href={book.href}
                        target="_blank"
                      >
                        <img
                          alt={book.alt}
                          src={assetHref(
                            currentRoute,
                            book.imageLocal.replace(/^\/+/, ""),
                          )}
                          loading="lazy"
                          decoding="async"
                        />
                      </a>
                    </div>
                  ))
                }
                <div class="gr_grid_book_placeholder">
                  <a href={statsBooksHref}>Browse all my reads</a>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <PageFooter
        footerHtml={content.footerHtml}
        lastUpdatedLabel={uiLabels.lastUpdated}
        timestampIso={buildTimestamp.iso}
        timestampDisplay={buildTimestamp.display}
      />
    </div>

    <BackToTopButton label={uiLabels.backToTop} />
    <script>
      import "../../scripts/entries/index-page";
    </script>
  </body>
</html>
