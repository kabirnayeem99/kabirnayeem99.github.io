---
import type { MainNavItem } from "../../lib/main-nav";

interface Props {
  readonly items: readonly MainNavItem[];
  readonly ariaLabel?: string;
}

const { items, ariaLabel = "Primary" } = Astro.props as Props;
---

<nav class="page-nav" aria-label={ariaLabel}>
  <div class="page-nav-track">
    {
      items.map((item, index) => (
        <a
          class="page-nav-link"
          href={item.href}
          aria-current={item.isCurrent ? "page" : undefined}
        >
          <span class="page-nav-link-index" aria-hidden="true">
            {String(index + 1).padStart(2, "0")}
          </span>
          <span class="page-nav-link-label">{item.label}</span>
        </a>
      ))
    }
  </div>
</nav>
