---
interface Props {
  readonly footerHtml: string;
  readonly lastUpdatedLabel: string;
  readonly timestampIso: string;
  readonly timestampDisplay: string;
}

const { footerHtml, lastUpdatedLabel, timestampIso, timestampDisplay } =
  Astro.props;
---

<footer>
  <p class="footer-copy" set:html={footerHtml} />
  <p class="footer-last-updated">
    {lastUpdatedLabel}
    <time datetime={timestampIso}>{timestampDisplay}</time>
  </p>
</footer>
