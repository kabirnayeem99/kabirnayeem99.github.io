---
import PageNav from "./PageNav.astro";
import { buildMainNav } from "../../lib/main-nav";

interface Props {
  readonly homeHref: string;
  readonly closeLabel: string;
  readonly title: string;
  readonly currentRoute: string;
}

const {
  homeHref,
  closeLabel,
  title,
  currentRoute,
} = Astro.props as Props;
const navItems = buildMainNav(currentRoute);
---

<header id="top">
  <div class="page-header-top">
    <div class="page-closebar">
      <a
        class="page-close-button"
        href={homeHref}
        aria-label={closeLabel}
        title={closeLabel}
        ><span class="page-close-icon" aria-hidden="true"></span></a
      >
      <h1 class="site-title site-title--page">{title}</h1>
    </div>
  </div>
  <PageNav items={navItems} />
</header>
