---
import ClosePageHeader from "./ClosePageHeader.astro";
import HeadSeo from "./HeadSeo.astro";
import PageFooter from "./PageFooter.astro";
import goodreadsSnapshot from "../../data/site-content/goodreads-snapshot.json";
import { computeLegacyBuildTimestamp } from "../../lib/build-timestamp";
import {
  buildOgImageUrl,
  buildPageAssetHrefs,
  PAGE_LAYOUT,
  UMAMI_WEBSITE_ID,
} from "../../lib/page-shared";
import { buildSchemaGraphJson } from "../../lib/seo";
import { loadStatsPageContent, statsEmbedThemeSources } from "../../lib/stats-content";
import {
  assetHref,
  buildAlternateLinks,
  buildOgLocaleAlternates,
  OG_LOCALE_BY_LANG,
  routeHref,
} from "../../lib/work-project-content";
import type { Lang } from "../../lib/site-types";

interface Props {
  readonly lang: Lang;
}

const { lang } = Astro.props as Props;
const content = loadStatsPageContent(lang);
const buildTimestamp = computeLegacyBuildTimestamp(lang);
const canonicalUrl = `${content.site.baseUrl}/${content.route}`;
const ogImageUrl = buildOgImageUrl(content.site.baseUrl);
const schemaGraphJson = buildSchemaGraphJson({
  baseUrl: content.site.baseUrl,
  websiteName: content.site.websiteName,
  personName: content.site.personName,
  canonicalUrl,
  ogImageUrl,
  socialProfiles: content.site.socialProfiles,
});

const alternateLinks = buildAlternateLinks(content.site.baseUrl, content.pageRoutes);

const [leetcodeLightSrc, leetcodeDarkSrc] = statsEmbedThemeSources(
  content.sections.leetcode.cardSrc,
  "leetcode",
);
const [roadmapLightSrc, roadmapDarkSrc] = statsEmbedThemeSources(
  content.sections.learningPath.imageSrc,
  "roadmap",
);
const [roadmapLightHref, roadmapDarkHref] = statsEmbedThemeSources(
  content.sections.learningPath.href,
  "roadmap",
);

const homeHref = routeHref(content.route, content.homeRoute);
const pageAssets = buildPageAssetHrefs(content.route);
const ogLocaleAlternates = buildOgLocaleAlternates(lang);
const uiLabels = content.site.locale.labels;
const goodreadsScriptSource = (() => {
  try {
    const parsed = new URL(content.sections.goodreads.scriptSrc);
    parsed.searchParams.set("num_books", "300");
    return parsed.toString();
  } catch {
    return content.sections.goodreads.scriptSrc;
  }
})();
const goodreadsBooks = goodreadsSnapshot.books.slice(0, 300);
---

<!DOCTYPE html>
<html lang={lang} dir={content.site.locale.dir}>
  <HeadSeo
    title={content.meta.title}
    description={content.meta.description}
    keywords={content.meta.keywords}
    author={content.site.locale.author}
    canonicalUrl={canonicalUrl}
    alternateLinks={alternateLinks}
    ogType="article"
    ogLocale={OG_LOCALE_BY_LANG[lang]}
    ogLocaleAlternates={ogLocaleAlternates}
    ogImageUrl={ogImageUrl}
    ogImageAlt={content.site.locale.ogImageAlt}
    twitterSite={content.site.twitterSite}
    schemaGraphJson={schemaGraphJson}
    googleSiteVerification={content.site.googleSiteVerification}
    umamiWebsiteId={UMAMI_WEBSITE_ID}
    stylesheetHref={pageAssets.stylesheetHref}
    favicon32Href={pageAssets.favicon32Href}
    favicon16Href={pageAssets.favicon16Href}
    faviconIcoHref={pageAssets.faviconIcoHref}
    appleTouchIconHref={pageAssets.appleTouchIconHref}
    manifestHref={pageAssets.manifestHref}
  />
  <body
    data-page-id="stats"
    data-sw-path={pageAssets.swPath}
    data-goodreads-script-src={goodreadsScriptSource}
  >
    <a class={PAGE_LAYOUT.skipLinkClass} href={`#${PAGE_LAYOUT.mainContentId}`}>
      {uiLabels.skipToMain}
    </a>
    <div class={PAGE_LAYOUT.siteClass}>
      <ClosePageHeader
        homeHref={homeHref}
        closeLabel={uiLabels.closePage}
        title={content.header.siteTitle}
      />
      <main id={PAGE_LAYOUT.mainContentId}>
        <section>
          {content.intro.map((paragraph) => <p>{paragraph}</p>)}
        </section>
        <section>
          <div class="summary-card stats-card">
            <h2 class="section-title">{content.sections.wakatime.title}</h2>
            <div
              class="wakatime-widget"
              data-wakatime-widget
              data-wakatime-languages-url={content.sections.wakatime.languagesUrl}
              data-wakatime-summary-url={content.sections.wakatime.summaryUrl}
            >
              <p class="wakatime-status" data-role="status">{content.sections.wakatime.statusText}</p>
              <div class="wakatime-visuals" data-role="visuals" hidden>
                <div class="wakatime-summary" data-role="summary-cards"></div>
                <div class="wakatime-language-chart" data-role="language-chart">
                  <div class="wakatime-donut" data-role="language-donut"></div>
                  <div class="wakatime-donut-center" data-role="language-donut-center"></div>
                  <ol
                    class="wakatime-legend"
                    data-role="language-bars"
                    aria-label={content.sections.wakatime.ariaLabel}
                  ></ol>
                </div>
              </div>
            </div>
          </div>
        </section>
        <section>
          <div class="summary-card stats-card">
            <h2 class="section-title">{content.sections.githubCommits.title}</h2>
            <p>{content.sections.githubCommits.description}</p>
            <div
              class="github-commits-widget"
              data-github-commits-widget
              data-github-contrib-url={content.sections.githubCommits.contribUrl}
            >
              <p class="github-commits-status" data-role="status">
                {content.sections.githubCommits.statusText}
              </p>
              <div class="github-commits-visuals" data-role="visuals" hidden>
                <div class="github-commits-summary" data-role="summary-cards"></div>
                <div class="github-heatmap-wrap">
                  <div class="github-heatmap-scroll">
                    <div
                      class="github-heatmap"
                      data-role="heatmap"
                      aria-label={content.sections.githubCommits.heatmapAriaLabel}
                    ></div>
                  </div>
                  <div
                    class="github-heatmap-legend"
                    data-role="legend"
                    aria-label={content.sections.githubCommits.legendAriaLabel}
                  ></div>
                </div>
              </div>
            </div>
            <p class="meta">
              {content.sections.githubCommits.sourceLabel}{" "}
              <a href={content.sections.githubCommits.sourceHref} target="_blank" rel="noreferrer"
                >{content.sections.githubCommits.sourceText}</a
              >
            </p>
          </div>
        </section>
        <section>
          <div class="summary-card stats-card">
            <h2 class="section-title">{content.sections.leetcode.title}</h2>
            <p set:html={content.sections.leetcode.copy}></p>
            <p><sub set:html={content.sections.leetcode.thanks}></sub></p>
            <img
              data-hide-section-on-error="true"
              class="stats-embed stats-embed--leetcode-card"
              src={leetcodeLightSrc}
              data-theme-light-src={leetcodeLightSrc}
              data-theme-dark-src={leetcodeDarkSrc}
              alt={content.sections.leetcode.cardAlt}
              width="500"
              height="250"
              decoding="async"
              loading="lazy"
            />
          </div>
        </section>
        <section>
          <div class="summary-card stats-card">
            <h2 class="section-title">{content.sections.learningPath.title}</h2>
            <p set:html={content.sections.learningPath.copy}></p>
            <a
              class="stats-embed-link stats-embed-link--roadmap"
              href={roadmapLightHref}
              data-theme-light-href={roadmapLightHref}
              data-theme-dark-href={roadmapDarkHref}
            >
              <img
                data-hide-section-on-error="true"
                class="stats-embed stats-embed--roadmap-card"
                src={roadmapLightSrc}
                data-theme-light-src={roadmapLightSrc}
                data-theme-dark-src={roadmapDarkSrc}
                alt={content.sections.learningPath.imageAlt}
                width="1130"
                height="380"
                decoding="async"
                loading="lazy"
              />
            </a>
          </div>
        </section>
        <section>
          <div class="summary-card stats-card">
            <h2 class="section-title">{content.sections.goodreads.title}</h2>
            <p>{content.sections.goodreads.copy}</p>
            <div class="goodreads-widget" id={`gr_grid_widget_${content.sections.goodreads.widgetId}`}>
              <div class="gr_grid_container">
                {goodreadsBooks.map((book) => (
                  <div class="gr_grid_book_container">
                    <a title={book.title} rel="nofollow noreferrer" href={book.href} target="_blank">
                      <img
                        alt={book.alt}
                        src={assetHref(content.route, book.imageLocal.replace(/^\/+/, ""))}
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  </div>
                ))}
              </div>
            </div>
            <p class="goodreads-profile-link">
              <a href={content.sections.goodreads.profileHref} target="_blank" rel="noreferrer"
                >{content.sections.goodreads.profileLabel}</a
              >
            </p>
          </div>
        </section>
      </main>
      <PageFooter
        footerHtml={content.footerHtml}
        lastUpdatedLabel={uiLabels.lastUpdated}
        timestampIso={buildTimestamp.iso}
        timestampDisplay={buildTimestamp.display}
      />
    </div>
    <script>
      import "../../scripts/entries/stats-page";
    </script>
  </body>
</html>
