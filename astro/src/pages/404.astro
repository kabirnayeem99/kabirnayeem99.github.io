---
// GitHub Pages serves 404.html with a proper 404 HTTP status for any missing URL.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found — Naimul Kabir</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png" />
  </head>
  <body>
    <div class="site">
      <main id="main-content">
        <section style="padding: 4rem 2rem; text-align: center;">
          <h1>Page Not Found</h1>
          <p>The page you were looking for doesn't exist or has been moved.</p>
          <a href="/" class="action-chip action-chip--primary" style="display: inline-flex; margin-top: 1.5rem;">
            <span>Go back home</span>
          </a>
        </section>
      </main>
    </div>
  </body>
</html>
